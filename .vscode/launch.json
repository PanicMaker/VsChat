{
  "version": "0.2.0",
  "compounds": [
    {
      "name": "Run Extension",
      "configurations": ["Extension"],
      "preLaunchTask": "npm: watch"
    }
  ],
  "configurations": [
    {
      "name": "Extension",
      "type": "extensionHost",
      "request": "launch",
      "runtimeExecutable": "${execPath}",
      "args": ["--extensionDevelopmentPath=${workspaceFolder}"],
      "outFiles": ["${workspaceFolder}/dist/**/*.js"],
      "preLaunchTask": "npm: compile"
    }
  ]
}
